{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "moduleDetection": "force",
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["pwa/js/**/*.js", "pwa/js/**/*.d.ts"]
}
