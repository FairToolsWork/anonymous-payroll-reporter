{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "packages": {
        ".": {
            "release-type": "node",
            "extra-files": [
                {
                    "type": "generic",
                    "path": "pwa/sw.js"
                },
                {
                    "type": "generic",
                    "path": "pwa/index.html",
                    "replace": [
                        {
                            "search": "anonymous-payroll-reporter-v\\d+\\.\\d+\\.\\d+",
                            "replace": "anonymous-payroll-reporter-v${version}"
                        }
                    ]
                }
            ]
        }
    }
}
