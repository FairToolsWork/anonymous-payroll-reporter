{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "packages": {
        ".": {
            "release-type": "node",
            "extra-files": [
                {
                    "type": "generic",
                    "path": "pwa/sw.js"
                },
                {
                    "type": "generic",
                    "path": "pwa/index.html",
                    "replace": [
                        {
                            "search": "<meta name=\"app-version\" content=\"\\d+\\.\\d+\\.\\d+\" />",
                            "replace": "<meta name=\"app-version\" content=\"${version}\" />"
                        }
                    ]
                }
            ]
        }
    }
}
