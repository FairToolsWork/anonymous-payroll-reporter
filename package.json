{
    "name": "anonymous-payroll-reporter",
    "version": "3.4.4",
    "type": "module",
    "private": true,
    "author": "bnjmnrsh",
    "license": "MIT",
    "description": "Payroll PDF Processor PWA and test/fixture tooling",
    "scripts": {
        "fixtures:pdf": "./generate_fixtures/.venv/bin/python generate_fixtures/generate_pdf_fixtures.py",
        "fixtures:expected-pdf": "vitest run tests/utils/regenerate_expected_payslips.test.mjs",
        "fixtures:print-pdf-text": "./generate_fixtures/.venv/bin/python generate_fixtures/print_pdf_text.py",
        "fixtures:excel": "./generate_fixtures/.venv/bin/python generate_fixtures/generate_excel_fixtures.py",
        "fixtures:expected-excel": "node tests/utils/regenerate_expected_contributions.mjs",
        "fixtures:print-excel-text": "./generate_fixtures/.venv/bin/python generate_fixtures/print_excel_text.py",
        "fixtures:patterns": "node generate_fixtures/formats/sage-uk/generate_patterns.mjs",
        "fixtures:check:pdf": "./generate_fixtures/.venv/bin/python generate_fixtures/generate_pdf_fixtures.py --check",
        "fixtures:check:excel": "./generate_fixtures/.venv/bin/python generate_fixtures/generate_excel_fixtures.py --check",
        "fixtures:check": "pnpm fixtures:check:pdf && pnpm fixtures:check:excel",
        "fixtures:generate": "pnpm fixtures:patterns && pnpm fixtures:pdf && pnpm fixtures:expected-pdf && pnpm fixtures:excel && pnpm fixtures:expected-excel && pnpm fixtures:demo:zip",
        "fixtures:demo:zip": "node generate_fixtures/zip_demo.mjs --dirs=good-place:demo_files/good-place,compliance-adjacent:demo_files/compliance-adjacent",
        "test:pdf_parse": "vitest run tests/pdf_parse.test.mjs",
        "test:excel_contribution": "vitest run tests/excel_contribution.test.mjs",
        "test:report_calc": "vitest run tests/report_calculation.test.mjs",
        "test:all": "vitest run",
        "test:coverage": "vitest run --coverage",
        "check:js": "tsc -p tsconfig.json",
        "jslint": "eslint .",
        "jslint:fix": "eslint . --fix",
        "csslint": "stylelint .",
        "csslint:fix": "stylelint . --fix",
        "format": "prettier --write .",
        "precommit": "pnpm format && pnpm jslint && pnpm csslint && pnpm check:js && pnpm fixtures:check && pnpm pwa:build && pnpm test:all",
        "prepare": "husky install",
        "pwa:dev": "vite",
        "pwa:build": "vite build",
        "pwa:generate": "node node_modules/.pnpm/pwa-asset-generator@8.1.2/node_modules/pwa-asset-generator/dist/cli.js pwa/public/icons/icon.svg pwa/public/icons --scrape false --type png --padding \"12%\" --background \"#f4ebd4\" --manifest pwa/public/site.webmanifest --index pwa/index.html --path-override \"/icons\"",
        "cf:deploy": "wrangler deploy",
        "cf:deploy:build": "pnpm pwa:build && wrangler deploy",
        "cf:preview": "wrangler versions upload",
        "cf:preview:build": "pnpm pwa:build && wrangler versions upload"
    },
    "prettier": {
        "trailingComma": "es5",
        "tabWidth": 4,
        "semi": false,
        "singleQuote": true
    },
    "dependencies": {
        "canvas": "3.2.1",
        "jspdf": "^4.2.0",
        "jspdf-autotable": "^5.0.7",
        "pdfjs-dist": "5.4.149"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vitest/coverage-v8": "4.0.18",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "prettier": "^3.8.1",
        "pwa-asset-generator": "^8.1.2",
        "jsonc-parser": "3.3.1",
        "stylelint": "^17.4.0",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "^5.9.3",
        "vue": "3.5.22",
        "vite": "^5.4.0",
        "vitest": "4.0.18",
        "xlsx": "^0.18.5"
    },
    "pnpm": {
        "overrides": {
            "canvas": "3.2.1"
        },
        "patchedDependencies": {
            "pwa-asset-generator": "patches/pwa-asset-generator.patch"
        }
    },
    "packageManager": "pnpm@9.15.2+sha512.93e57b0126f0df74ce6bff29680394c0ba54ec47246b9cf321f0121d8d9bb03f750a705f24edc3c1180853afd7c2c3b94196d0a3d53d3e069d9e2793ef11f321"
}
