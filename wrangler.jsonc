{
    "$schema": "node_modules/.pnpm/wrangler@4.69.0/node_modules/wrangler/config-schema.json",
    "name": "anonymous-payroll-reporter",
    "main": "src/worker.js",
    "compatibility_date": "2025-03-03",
    "assets": {
        "directory": "./pwa",
        "binding": "ASSETS",
    },
    "routes": [
        {
            "pattern": "payroll-beta.fairtools.work/*",
            "zone_name": "fairtools.work",
        },
    ],
}
